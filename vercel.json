{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "vercel-python@0.1.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": "/api/generate.py"
    },
    {
      "source": "/api/tasks/(.*)",
      "destination": "/api/tasks.py?taskId=$1"
    },
    {
      "source": "/api/enhance-prompt",
      "destination": "/api/enhance.py"
    },
    {
      "source": "/api/upload-imgbb",
      "destination": "/api/upload.py"
    },
    {
      "source": "/api/download",
      "destination": "/api/download.py"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
