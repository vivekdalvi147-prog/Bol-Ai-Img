rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /generations/{docId} {
      // Allow anyone to read a specific document if they have the ID (for shared links)
      allow get: if true;
      
      // Only the owner can list their own documents (for "My Creations" tab)
      allow list: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Only authenticated users can create, and they must set themselves as the owner
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Only the owner can update or delete their documents
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
